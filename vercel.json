{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/offer-reminders",
      "schedule": "0 8,18 * * *"
    },
    {
      "path": "/api/cron/recurring-offers",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/cleanup-analytics",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/end-auctions",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/workshop-payments",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/x-leads-collect",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/cleanup-print-orders",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/message-nudges",
      "schedule": "0 9,19 * * *"
    },
    {
      "path": "/api/cron/purge-deleted-accounts",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/offline-models",
      "schedule": "* * * * *"
    }
  ]
}
